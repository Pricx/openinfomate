# Tracker configuration (copy to .env and fill in)

# DB
TRACKER_DB_URL=sqlite:///./tracker.db
# Optional: override env file path (useful for systemd services)
# TRACKER_ENV_PATH=.env

# Logging
# TRACKER_LOG_LEVEL=INFO

# API (optional)
# TRACKER_API_HOST=127.0.0.1
# TRACKER_API_PORT=8080
# TRACKER_API_TOKEN=change-me
#
# Admin auth (recommended when binding to 0.0.0.0)
# TRACKER_ADMIN_USERNAME=admin
# TRACKER_ADMIN_PASSWORD=change-me
# TRACKER_ADMIN_ALLOW_REMOTE_ENV_UPDATE=false
# Bootstrap (unsafe): allow starting without auth on non-localhost bind.
# Intended for first-run setup behind localhost-only exposure (e.g. Docker binding to 127.0.0.1).
# TRACKER_BOOTSTRAP_ALLOW_NO_AUTH=false

# Web Admin "Restart" button (systemd --user unit names)
# TRACKER_SYSTEMD_USER_UNIT_SCHEDULER=tracker
# TRACKER_SYSTEMD_USER_UNIT_API=tracker-api

# Push behavior
# TRACKER_PUSH_MAX_ATTEMPTS=3
# Per-channel toggles (optional; defaults to true when configured)
# TRACKER_PUSH_DINGTALK_ENABLED=true
# Retry failed pushes (optional)
# TRACKER_PUSH_RETRY_CRON=0 * * * *  # crontab (empty = disable)
# TRACKER_PUSH_RETRY_MAX_KEYS=20
# TRACKER_MAX_CONCURRENT_FETCHES=10
# TRACKER_MAX_CONCURRENT_FETCHES_PER_HOST=2
# TRACKER_MAX_CONCURRENT_DIGESTS=2
# TRACKER_HOST_MIN_INTERVAL_SECONDS=0
# Global domain filters (optional; comma-separated)
# If INCLUDE is set, only matching hosts are kept (best-effort).
# EXCLUDE always wins.
# Example (optional): exclude common low-signal repost/SEO domains (tune to your taste).
# TRACKER_EXCLUDE_DOMAINS=csdn.net,facebook.com,instagram.com,linkedin.com
# TRACKER_INCLUDE_DOMAINS=
#
# Domain quality tiering (optional; complements include/exclude)
# - Tiers: low | medium | high | unknown
# - unknown is treated as "medium" by default (so you don't accidentally drop new domains).
# - Default policy: low domains are excluded from *push*.
# TRACKER_DOMAIN_QUALITY_MIN_TIER_FOR_PUSH=medium
# TRACKER_DOMAIN_QUALITY_LOW_DOMAINS=csdn.net
# TRACKER_DOMAIN_QUALITY_MEDIUM_DOMAINS=cnblogs.com
# TRACKER_DOMAIN_QUALITY_HIGH_DOMAINS=arxiv.org,github.com,openai.com
# Legacy keyword prefilter (optional; not AI-native).
# When disabled (default), bindings' `include_keywords` will NOT hard-filter ingestion in keywords mode.
# TRACKER_INCLUDE_KEYWORDS_PREFILTER_ENABLED=false
# TRACKER_SIMHASH_LOOKBACK_DAYS=30
# TRACKER_CRON_TIMEZONE=UTC  # IANA timezone name (e.g. UTC, Asia/Shanghai)
# Output language for background jobs (LLM writeups + push/report formatting).
# Supported: en|zh
# TRACKER_OUTPUT_LANGUAGE=en
# If a cron job is missed (e.g. service restart), run it once on resume within this grace window (seconds).
# Set 0 to disable misfire catch-up.
# TRACKER_CRON_MISFIRE_GRACE_SECONDS=21600
# Priority lane (optional): promote a few "must-push" signals to alerts quickly (SLA).
# TRACKER_PRIORITY_LANE_ENABLED=false
# TRACKER_PRIORITY_LANE_HOURS=72
# TRACKER_PRIORITY_LANE_POOL_MAX_CANDIDATES=200
# TRACKER_PRIORITY_LANE_TRIAGE_KEEP_CANDIDATES=20
# TRACKER_PRIORITY_LANE_MAX_ALERT=2
# TRACKER_DIGEST_SCHEDULER_ENABLED=true
# TRACKER_DIGEST_PUSH_ENABLED=true
# Digest lookback window (hours) for scheduled per-topic digests.
# TRACKER_DIGEST_HOURS=24
# TRACKER_HEALTH_REPORT_CRON=0 8 * * *  # crontab (empty = disable)
# TRACKER_BACKUP_CRON=0 3 * * *  # crontab (empty = disable)
# TRACKER_BACKUP_DIR=./backups
# TRACKER_BACKUP_KEEP_DAYS=30

# Retention / pruning (optional)
# TRACKER_PRUNE_IGNORED_CRON=0 4 * * *  # crontab (empty = disable)
# TRACKER_PRUNE_IGNORED_DAYS=180
# TRACKER_PRUNE_KEEP_ITEMS=false
# TRACKER_PRUNE_VACUUM=false

# Dynamic source discovery (optional)
# Creates a review queue of RSS/Atom feeds found from web-wide results (requires SearxNG sources).
# TRACKER_DISCOVER_SOURCES_CRON=15 2 * * *  # crontab (empty = disable)
# TRACKER_DISCOVER_SOURCES_MAX_RESULTS_PER_TOPIC=10
# Optional AI-assisted feed discovery (uses the configured OpenAI-compatible LLM).
# TRACKER_DISCOVER_SOURCES_AI_ENABLED=false
# TRACKER_DISCOVER_SOURCES_AI_MAX_PAGES_PER_TOPIC=2
# TRACKER_DISCOVER_SOURCES_AI_MAX_HTML_CHARS=50000
# TRACKER_DISCOVER_SOURCES_AI_MAX_FEED_URLS=10
# Optional auto-accept (prompt-driven; uses the configured OpenAI-compatible LLM).
# TRACKER_DISCOVER_SOURCES_AUTO_ACCEPT_ENABLED=false
# TRACKER_DISCOVER_SOURCES_AUTO_ACCEPT_MAX_PER_TOPIC=2
# TRACKER_DISCOVER_SOURCES_AUTO_ACCEPT_PREVIEW_ENTRIES=5

# Source policy (optional)
# TRACKER_RSS_MIN_INTERVAL_SECONDS=900
# TRACKER_HN_MIN_INTERVAL_SECONDS=900
# TRACKER_SEARXNG_MIN_INTERVAL_SECONDS=3600
# TRACKER_DISCOURSE_MIN_INTERVAL_SECONDS=900
# Optional Discourse cookie header (for private categories / Cloudflare clearance).
# Store as a raw `Cookie:` header value in `.env`. Never commit or export it.
# TRACKER_DISCOURSE_COOKIE=
# Optional cookie jar (domain/url -> raw Cookie header value) for login-required sources.
# Store in `.env` only; never commit or export.
# Example:
# TRACKER_COOKIE_JAR_JSON={"linux.do":"a=b; c=d", "github.com":"logged_in=yes; ..."}
# TRACKER_SOURCE_DISABLE_AFTER_ERRORS=10
# TRACKER_SOURCE_BACKOFF_BASE_SECONDS=60
# TRACKER_SOURCE_BACKOFF_MAX_SECONDS=3600

# DingTalk webhook (optional)
# TRACKER_DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=...
# TRACKER_DINGTALK_SECRET=SEC...  # optional signing secret (if enabled in DingTalk)

# Telegram (optional)
# 1) Create a bot via @BotFather, then set TRACKER_TELEGRAM_BOT_TOKEN
# 2) In the admin UI (/setup/push), generate a connect link and click /start to bind chat_id
# TRACKER_TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# TRACKER_TELEGRAM_BOT_USERNAME=YourBotName
# TRACKER_TELEGRAM_CHAT_ID=  # optional fallback (prefer UI connect)
# TRACKER_TELEGRAM_DISABLE_PREVIEW=true
# Optional "private bot" hardening: if set, only this Telegram user id may bind / issue commands.
# TRACKER_TELEGRAM_OWNER_USER_ID=
# Optional: background polling to auto-bind chat_id after you click the connect link.
# TRACKER_TELEGRAM_CONNECT_POLL_SECONDS=60
# Optional: use Telegram-native Reader UI (single message + inline buttons) for per-topic digests.
# TRACKER_TELEGRAM_DIGEST_READER_ENABLED=true
# Optional: when using Digest Reader, show per-item feedback buttons (👍/👎/🔕) inside the reader.
# TRACKER_TELEGRAM_DIGEST_ITEM_FEEDBACK_ENABLED=true
# Optional: feedback controls (reactions + replies) for preference learning.
# TRACKER_TELEGRAM_FEEDBACK_REACTIONS_ENABLED=true
# TRACKER_TELEGRAM_FEEDBACK_REPLIES_ENABLED=true
# Optional: customize emoji mappings (comma/space-separated).
# TRACKER_TELEGRAM_FEEDBACK_LIKE_EMOJIS=👍,❤️,🔥,⭐,🌟
# TRACKER_TELEGRAM_FEEDBACK_DISLIKE_EMOJIS=👎,💩,😡,🤮,❌
# TRACKER_TELEGRAM_FEEDBACK_MUTE_EMOJIS=🔕

# Generic webhook (optional)
# TRACKER_WEBHOOK_URL=https://example.com/your/webhook

# Email (SMTP) (optional)
# TRACKER_SMTP_HOST=smtp.example.com
# TRACKER_SMTP_PORT=587
# TRACKER_SMTP_USER=you@example.com
# TRACKER_SMTP_PASSWORD=your-password
# TRACKER_SMTP_STARTTLS=true
# TRACKER_SMTP_USE_SSL=false  # for port 465, set true and disable starttls
# TRACKER_EMAIL_FROM=you@example.com
# TRACKER_EMAIL_TO=you@example.com

# LLM (optional; OpenAI-compatible) — hybrid alert gate
# Enable by setting both `TRACKER_LLM_BASE_URL` and `TRACKER_LLM_MODEL`.
# Examples:
# - Ollama OpenAI compatibility: http://127.0.0.1:11434
# - vLLM OpenAI server: http://127.0.0.1:8000
# TRACKER_LLM_BASE_URL=http://127.0.0.1:11434
# TRACKER_LLM_API_KEY=  # optional
# TRACKER_LLM_PROXY=  # optional (httpx proxy=...); if unset uses env/system proxy if any
# TRACKER_LLM_MODEL=your-model-name
# Optional model routing:
# - reasoning: for selection/curation (default: TRACKER_LLM_MODEL)
# - mini: for compression-only tasks (default: TRACKER_LLM_MODEL)
# TRACKER_LLM_MODEL_REASONING=
# TRACKER_LLM_MODEL_MINI=gpt-5.1-codex-mini
# Optional separate provider for mini/triage workloads (cheap, high-throughput).
# If unset, mini tasks fall back to the main TRACKER_LLM_* provider.
# TRACKER_LLM_MINI_BASE_URL=
# TRACKER_LLM_MINI_API_KEY=
# TRACKER_LLM_MINI_PROXY=
# Optional extra request body JSON merged into every OpenAI-compatible request.
# Useful for provider knobs like reasoning effort. Forbidden keys are ignored: model, messages, stream.
# TRACKER_LLM_EXTRA_BODY_JSON={"reasoning":{"effort":"xhigh"}}
# TRACKER_LLM_TIMEOUT_SECONDS=30
# TRACKER_LLM_MAX_CANDIDATES_PER_TICK=10
# Optional cost estimation (USD per 1M tokens).
# If unset/0, Tracker will still record token counts (when the backend reports them),
# but cost will show as "unknown" in `tracker llm usage`.
# TRACKER_LLM_PRICE_INPUT_PER_MILLION_USD=0
# TRACKER_LLM_PRICE_OUTPUT_PER_MILLION_USD=0
# TRACKER_LLM_DIGEST_ENABLED=false
# TRACKER_LLM_DIGEST_MAX_ITEMS=20
# Prompt-driven LLM curation (AI-native selection):
# TRACKER_LLM_CURATION_ENABLED=false
# TRACKER_LLM_CURATION_MAX_CANDIDATES=30
# TRACKER_LLM_CURATION_MAX_DIGEST=5
# TRACKER_LLM_CURATION_MAX_ALERT=2
# TRACKER_LLM_CURATION_HISTORY_DEDUPE_DAYS=30
# Reliability: if LLM curation fails, optionally send a small fallback digest instead of going silent.
# TRACKER_LLM_CURATION_FAIL_OPEN=true
# TRACKER_LLM_CURATION_FAIL_OPEN_MAX_DIGEST=3
# Optional cheap triage stage before full curation (uses TRACKER_LLM_MODEL_MINI):
# TRACKER_LLM_CURATION_TRIAGE_ENABLED=false
# TRACKER_LLM_CURATION_TRIAGE_POOL_MAX_CANDIDATES=120
# TRACKER_LLM_CURATION_TRIAGE_KEEP_CANDIDATES=0

# Full-text enrichment (optional; improves AI curation + summaries)
# TRACKER_FULLTEXT_ENABLED=false
# TRACKER_FULLTEXT_TIMEOUT_SECONDS=20
# TRACKER_FULLTEXT_MAX_CHARS=60000
# TRACKER_FULLTEXT_MAX_FETCHES_PER_TOPIC=8

# Web search backend (optional; improves source discovery / Smart Config autofix)
# TRACKER_SEARXNG_BASE_URL=http://127.0.0.1:8888
